# Model serving (open source)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
RCA_MODEL=qwen3:8b
RCA_PROMPT_VERSION=v3
RCA_MAX_RETRIES=2
RCA_MAX_OUTPUT_TOKENS=4096
RCA_REQUEST_TIMEOUT_SECONDS=120
RCA_AGENT_TIMEOUT_SECONDS=420
RCA_MAX_REVISE_ROUNDS=2
RCA_VALIDATION_ENABLED=true
VALIDATION_MODEL=llama3.2:latest
RCA_EVAL_MODELS=qwen3:8b,llama3.2:latest

# Optional hosted-open provider / validation pass
# LLM_PROVIDER=hosted
# HOSTED_OPEN_BASE_URL=https://api.groq.com/openai/v1
# HOSTED_OPEN_API_KEY=replace-me
# HOSTED_OPEN_MODEL=llama-3.1-70b-versatile
# VALIDATION_MODEL=llama-3.1-70b-versatile

# Sanitizer (Phase 5)
RCA_MAX_INPUT_CHARS=6000
RCA_MAX_CONTEXT_CHARS=12000

# Past RCA memory
RCA_MEMORY_ENABLED=true
RCA_MEMORY_PATH=./data/past_rca_memory_sample_repaired.xlsx
RCA_MEMORY_MAX_MATCHES=3
RCA_MEMORY_MIN_SCORE=0.50
# Opt in only after reviewing retention and spreadsheet trust boundaries.
RCA_MEMORY_WRITEBACK_ENABLED=false

# Output
OUTPUT_DIR=./outputs
LOG_LEVEL=INFO

# Optional Auth0 OAuth / RBAC protection
# Leave AUTH_ENABLED=false for local unauthenticated development.
AUTH_ENABLED=false
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://rca-assistant.local/api
AUTH0_ALGORITHMS=RS256
AUTH_ADMIN_PERMISSION=rca:admin

# Vite frontend Auth0 settings (put these in frontend/.env for dev builds)
VITE_AUTH_ENABLED=false
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=replace-with-spa-client-id
VITE_AUTH0_AUDIENCE=https://rca-assistant.local/api
